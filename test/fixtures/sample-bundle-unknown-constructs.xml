<?xml version="1.0" encoding="UTF-8"?>
<!--
  SYNTHETIC SAMPLE DATA - exercises unrecognized/ambiguous constructs that the
  parser should flag instead of guessing about.
-->
<Bundle>
  <Name>Legacy Tool</Name>
  <Guid>aaaaaaaa-bbbb-cccc-dddd-eeeeeeeeeeee</Guid>
  <Type>Install</Type>

  <Requirements>
    <Filter type="CustomZenAppFingerprint" operator="equals" value="unknown-to-us" />
  </Requirements>

  <Dependencies>
    <Dependency type="Bundle" guid="ffffffff-0000-1111-2222-333333333333" required="false" />
  </Dependencies>

  <ActionSets>
    <ActionSet type="Install">
      <Action type="RegistrySweep" order="1">
        <Path>HKLM\Software\LegacyTool</Path>
      </Action>
    </ActionSet>
  </ActionSets>
</Bundle>
